# ==============================
# 服务器配置
# ==============================

# 服务绑定地址
SERVER_HOST=localhost

# 服务端口
SERVER_PORT=3000

# 数据库连接地址（仅 DB_ADAPTER=pg 时生效）
# 格式：postgres://用户名:密码@主机:端口/数据库名
# 本地示例：postgres://postgres:postgres@localhost:5432/tech_club
# 腾讯云 CloudBase RDB 示例：postgres://user@host:port/dbname?schema=tech_hub
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tech_club

# 数据库适配器类型
#   pg           - 直连 PostgreSQL（推荐本地开发与生产部署，详见 server/database/pg-direct-adapter.ts）
#   留空或其他值  - 走腾讯云 CloudBase RDB 适配层，由 CloudBase 转发（详见 server/database/cloudbase-rdb-adapter.ts）
DB_ADAPTER=pg

# 数据库 schema（仅 PostgreSQL 有效）
#   pg 模式：自定义 schema 名，本地一般用 public
#   留空：使用数据库默认 schema
DB_SCHEMA=public


# ==============================
# 腾讯云 CloudBase 配置
# ==============================

# CloudBase 环境 ID
CLOUDBASE_ENV_ID=your-env-id

# CloudBase API Key（可选，某些场景需要）
CLOUDBASE_APIKEY=your-api-key

# CloudBase Session Token（可选，临时凭证）
CLOUDBASE_TOKEN=your-session-token


# ==============================
# 腾讯云 API 密钥
# ==============================

# 腾讯云 SecretId
TENCENTCLOUD_SECRETID=your-secret-id

# 腾讯云 SecretKey
TENCENTCLOUD_SECRETKEY=your-secret-key

# 腾讯云 SessionToken（可选，临时凭证）
TENCENTCLOUD_SESSIONTOKEN=

# 腾讯云地域（默认广州）
TENCENTCLOUD_REGION=ap-guangzhou


# ==============================
# 管理员配置
# ==============================

# 默认管理员昵称（初始化脚本使用）
ADMIN_NICKNAME=admin

# 默认管理员手机号（初始化脚本使用）
ADMIN_PHONE=13800138000


# ==============================
# 上传配置
# ==============================

# 上传文件的公共访问基础 URL（可选）
PUBLIC_UPLOAD_BASE_URL=


# ==============================
# 日志配置
# ==============================

# 是否打印请求体日志
LOG_REQUEST_BODY=true

# 是否打印响应体日志
LOG_RESPONSE_BODY=true


# ==============================
# Vite 开发服务器配置
# ==============================

# Vite 开发服务器绑定地址
VITE_HOST=127.0.0.1

# Vite 开发服务器端口
VITE_PORT=3001

# API 代理目标地址（后端服务地址）
VITE_API_URL=http://127.0.0.1:3002


# ==============================
# 网络配置
# ==============================

# 不使用代理的地址列表
NO_PROXY=localhost,127.0.0.1


# ==============================
# 环境变量（自动设置，无需手动配置）
# ==============================

# NODE_ENV - 运行环境：development | production

